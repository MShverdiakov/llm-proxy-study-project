{
  "uid": "llm-proxy",
  "title": "LLM Proxy",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Cache Hit/Miss Ratio",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(cache_hits_total[1m])",
          "legendFormat": "hits"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(cache_misses_total[1m])",
          "legendFormat": "misses"
        }
      ]
    },
    {
      "id": 2,
      "title": "Tokens by Model",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(llm_tokens_total[1m])) by (model)",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Requests by Provider",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{job=~\"llm-proxy.*\"}[5m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "LLM Provider Latency (p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"llm-proxy.*\"}[1m])) by (le))",
          "legendFormat": "p95 latency"
        }
      ]
    }
  ]
}
