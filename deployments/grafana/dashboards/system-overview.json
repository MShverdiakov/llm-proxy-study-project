{
  "uid": "system-overview",
  "title": "System Overview",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Goroutines per Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "go_goroutines",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "CPU Usage (seconds/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(process_cpu_seconds_total[1m])",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Resident Memory (MB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Network Receive (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(process_network_receive_bytes_total[1m])",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Network Transmit (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(process_network_transmit_bytes_total[1m])",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Open File Descriptors",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "process_open_fds",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
